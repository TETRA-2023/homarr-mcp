# Homarr instance URL
HOMARR_URL=http://localhost:7575

# API key (create in Management > Tools > API Keys)
HOMARR_API_KEY=your_api_key_here

# Transport mode: stdio (default) or streamable-http
HOMARR_TRANSPORT=stdio

# Optional: when set under HTTP transports (streamable-http / sse), every
# request must present 'Authorization: Bearer <token>'. No-op for stdio.
# MCP_BEARER_TOKEN=replace_with_a_random_secret
